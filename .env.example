# Shadow Web Scraper - Environment Variables

# Main Bot Token (from @BotFather)
BOT_TOKEN=your_main_bot_token_here

# Owner Chat IDs (comma separated, e.g., 123456789,987654321)
OWNER_IDS=your_telegram_chat_id_here

# Required Channel/Usernames for Join Verification
# Format: @channelusername or -1001234567890
TELEGRAM_CHANNEL=@your_telegram_channel
YOUTUBE_CHANNEL=@your_youtube_channel
WHATSAPP_CHANNEL=@your_whatsapp_channel

# Express Server Port (for Railway health checks)
PORT=3000

# Optional: MongoDB URL (if you want to use MongoDB instead of JSON)
# MONGODB_URI=
